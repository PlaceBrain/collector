APP__PORT=50054

LOGGING__LEVEL=info

# TimescaleDB (telemetry_db) — raw asyncpg, no SQLAlchemy driver prefix.
DATABASE__URL=postgresql://backend:change-me@placebrain-database:5432/telemetry_db
DATABASE__POOL_SIZE=10

# EMQX broker — subscribe to placebrain/# and publish alerts.
MQTT__URL=mqtt://placebrain-emqx:1883
MQTT__USERNAME=collector
MQTT__PASSWORD=collector

# In-memory batching before COPY into TimescaleDB.
BUFFER__MAX_SIZE=1000
BUFFER__FLUSH_INTERVAL=60

KAFKA__URL=placebrain-kafka:19092
REDIS__URL=redis://placebrain-redis:6379/0
